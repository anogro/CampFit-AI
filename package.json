{
  "name": "campfit-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "campfit:quality:backfill": "vite-node --config vitest.config.ts scripts/campfit/backfillProgramVerifications.ts",
    "campfit:v3:eval": "vite-node --config vitest.config.ts scripts/campfit/v3/counselingEvaluationCli.ts --mode=fallback",
    "campfit:v3:eval:fallback": "vite-node --config vitest.config.ts scripts/campfit/v3/counselingEvaluationCli.ts --mode=fallback",
    "campfit:v3:eval:mock": "vite-node --config vitest.config.ts scripts/campfit/v3/counselingEvaluationCli.ts --mode=mock",
    "campfit:v3:eval:live": "vite-node --config vitest.config.ts scripts/campfit/v3/counselingEvaluationCli.ts --mode=live",
    "campfit:v3:seed:demo": "vite-node --config vitest.config.ts tools/seed-campfit-v3-demo-programs.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
